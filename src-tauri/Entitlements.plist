<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- App Sandbox (REQUIRED for App Store) -->
  <key>com.apple.security.app-sandbox</key>
  <true/>

  <!-- Network access for AI APIs, Cloud Storage, OAuth -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- File access: user-selected files (Open/Save dialogs) -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>

  <!-- File access: bookmarks for recent files -->
  <key>com.apple.security.files.bookmarks.app-scope</key>
  <true/>

  <!-- Process execution (needed for Terminal, Git) -->
  <key>com.apple.security.temporary-exception.mach-lookup.global-name</key>
  <array>
    <string>com.apple.coreservices.launchservicesd</string>
  </array>
</dict>
</plist>
